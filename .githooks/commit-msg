#!/bin/sh
# Удаляет служебную строку Cursor из сообщения коммита перед записью коммита.
# Требует core.hooksPath = .githooks (см. настройку в репозитории).

commit_msg_file=$1
[ -n "$commit_msg_file" ] && [ -f "$commit_msg_file" ] || exit 0

# Точное совпадение и варианты с лишними пробелами вокруг «Cursor»
sed -i '' -E '/^Made-with:[[:space:]]*Cursor[[:space:]]*$/d' "$commit_msg_file"

exit 0
